{{ 'section-product-image-block.css' | asset_url | stylesheet_tag }}

{%- assign section_class = 'image-block--' | append: section.id -%}

<div
  class="image-block {{ section_class }}"
  role="region"
  aria-label="{{ section.settings.aria_label | escape }}"
>
  <div class="image-block__column image-block__column--left">
    <div class="image-block__image{% if section.settings.mobile_left_image == blank %} small-hide{% endif %}">
      {% if section.settings.left_image != blank %}
        {{
          section.settings.left_image
          | image_url: width: 1600
          | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1500, 1600', alt: section.settings.left_image.alt
        }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    {% if section.settings.mobile_left_image != blank %}
      <div class="image-block__image medium-hide large-up-hide">
        {{
          section.settings.mobile_left_image
          | image_url: width: 1200
          | image_tag: loading: 'lazy', widths: '375, 550, 750', alt: section.settings.mobile_left_image.alt
        }}
      </div>
    {% endif %}

    <div class="image-block__content">
      <div class="image-block__header">
        <h2 class="sparkles-title">
          {% if section.settings.enable_sparkles %}
            <span class="sparkles image-block__sparkles">
              <span class="sparkle sparkle--1">
                <svg width="21" height="28" viewBox="0 0 21 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.1001 12.9001H15.6001C15.5001 12.9001 15.5001 12.9001 15.4001 12.9001H12.9001C12.8001 12.9001 12.7001 12.8001 12.6001 12.8001C11.7001 12.4001 11.4001 11.4001 11.1001 10.5001C10.9001 9.8001 10.7001 9.2001 10.6001 8.5001V0.200098C10.6001 -0.0999023 10.2001 -0.0999023 10.2001 0.200098V10.0001C10.1001 10.6001 10.0001 11.2001 9.6001 11.7001C9.5001 11.8001 9.4001 12.0001 9.3001 12.1001C8.6001 12.7001 7.5001 12.8001 6.6001 12.8001H6.5001H0.200098C-0.0999023 12.8001 -0.0999023 13.2001 0.200098 13.2001H7.3001H7.4001C9.3001 14.4001 10.0001 16.7001 10.2001 18.9001V26.9001C10.2001 27.2001 10.6001 27.2001 10.6001 26.9001V18.7001C11.0001 17.1001 11.5001 15.5001 12.6001 14.3001L12.7001 14.2001C13.2001 13.8001 13.8001 13.5001 14.5001 13.3001H20.2001C20.4001 13.3001 20.4001 12.9001 20.1001 12.9001Z" fill="currentColor"></path>
                </svg>
              </span>
              <span class="sparkle sparkle--2">
                <svg width="21" height="28" viewBox="0 0 21 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.1001 12.9001H15.6001C15.5001 12.9001 15.5001 12.9001 15.4001 12.9001H12.9001C12.8001 12.9001 12.7001 12.8001 12.6001 12.8001C11.7001 12.4001 11.4001 11.4001 11.1001 10.5001C10.9001 9.8001 10.7001 9.2001 10.6001 8.5001V0.200098C10.6001 -0.0999023 10.2001 -0.0999023 10.2001 0.200098V10.0001C10.1001 10.6001 10.0001 11.2001 9.6001 11.7001C9.5001 11.8001 9.4001 12.0001 9.3001 12.1001C8.6001 12.7001 7.5001 12.8001 6.6001 12.8001H6.5001H0.200098C-0.0999023 12.8001 -0.0999023 13.2001 0.200098 13.2001H7.3001H7.4001C9.3001 14.4001 10.0001 16.7001 10.2001 18.9001V26.9001C10.2001 27.2001 10.6001 27.2001 10.6001 26.9001V18.7001C11.0001 17.1001 11.5001 15.5001 12.6001 14.3001L12.7001 14.2001C13.2001 13.8001 13.8001 13.5001 14.5001 13.3001H20.2001C20.4001 13.3001 20.4001 12.9001 20.1001 12.9001Z" fill="currentColor"></path>
                </svg>
              </span>
              <span class="sparkle sparkle--3">
                <svg width="17" height="18" viewBox="0 0 17 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8.1 0L9.1 3.6C10.2 5.5 11.8 7 13.7 8.1L16.5 9L13.7 10C11.8 11 10.2 12.6 9.1 14.5L8.1 18L7.1 14.5C6.1 12.6 4.5 11 2.5 10L0 9L2.6 8C4.5 7 6.1 5.4 7.2 3.5L8.1 0Z" fill="currentColor"></path>
                </svg>
              </span>
              <span class="sparkle sparkle--4">
                <svg width="4" height="4" viewBox="0 0 4 4" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1.6 3.1C0.7 3.1 0 2.4 0 1.5C0 0.7 0.7 0 1.6 0C2.5 0 3.2 0.7 3.2 1.5C3.2 2.4 2.4 3.1 1.6 3.1Z" fill="currentColor"></path>
                </svg>
              </span>
            </span>
          {% endif %}
          {{ section.settings.heading }}
        </h2>
      </div>

      {% if section.settings.body != blank %}
        <div class="rte">{{ section.settings.body }}</div>
      {% endif %}
    </div>
  </div>

  <div class="image-block__column image-block__column--right small-hide">
    <div class="image-block__image">
      {% if section.settings.right_image != blank %}
        {{
          section.settings.right_image
          | image_url: width: 1600
          | image_tag: loading: 'lazy', widths: '750, 1100, 1500, 1600', alt: section.settings.right_image.alt
        }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  </div>
</div>

<style>
  .{{ section_class }} {
    --image-block-background-color: {{ section.settings.background_color }};
    --image-block-text-color: {{ section.settings.text_color }};
  }
</style>

{% schema %}
{
  "name": "Product Image Block",
  "tag": "section",
  "class": "section section-product-image-block",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Image Block"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Scent"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Text",
      "default": "<p>Add your product story here.</p>"
    },
    {
      "type": "checkbox",
      "id": "enable_sparkles",
      "label": "Enable sparkles",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "mobile_left_image",
      "label": "Left image (mobile override)"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image (desktop)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9423a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Product Image Block"
    }
  ]
}
{% endschema %}
