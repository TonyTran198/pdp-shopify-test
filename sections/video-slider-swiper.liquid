{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
{{ 'section-video-slider-swiper.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'video-slider-swiper.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="video-slider-swiper section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.heading != blank -%}
    <h2 class="video-slider-swiper__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="video-slider-swiper__track" data-video-swiper>
    <div class="swiper">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide video-slider-swiper__slide" {{ block.shopify_attributes }}>
            <article class="video-slider-swiper__card">
              {%- if block.settings.video != blank -%}
                {{
                  block.settings.video
                  | video_tag:
                    loop: true,
                    muted: true,
                    controls: false,
                    playsinline: true,
                    class: 'video-slider-swiper__video',
                    image_size: '320x'
                }}
              {%- elsif block.settings.video_url != blank -%}
                <video
                  class="video-slider-swiper__video"
                  loop
                  muted
                  playsinline
                  preload="metadata"
                >
                  <source src="{{ block.settings.video_url | escape }}" type="video/mp4">
                </video>
              {%- elsif block.settings.image != blank -%}
                {%- liquid
                  assign image_alt = block.settings.image.alt
                  if image_alt == blank
                    assign image_alt_base = section.settings.image_alt_fallback
                    if image_alt_base == blank
                      assign image_alt_base = 'Video'
                    endif
                    assign image_alt = image_alt_base | append: ' ' | append: forloop.index
                  endif
                -%}
                {{
                  block.settings.image
                  | image_url: width: 480
                  | image_tag:
                    loading: 'lazy',
                    widths: '220, 320, 480',
                    class: 'video-slider-swiper__image',
                    alt: image_alt
                }}
              {%- endif -%}
            </article>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video slider swiper",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Tiger Tribe"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "image_alt_fallback",
      "label": "Image alt fallback",
      "default": "Video"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Video item",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify hosted video"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "MP4 URL (fallback)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image fallback"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Video slider swiper",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
