{{ 'section-product-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-faq.js' | asset_url }}" defer="defer"></script>

<div
  class="product-faq product-faq--{{ section.id }}"
  role="region" 
  aria-label="{{ section.settings.aria_label | escape }}"
  data-product-faq
  data-product-faq-load-more-after="{{ section.settings.load_more_after }}"
>
  <div class="product-faq__column product-faq__column--left">
    <div class="product-faq__image">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1440
          | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1440', alt: section.settings.image.alt
        }}
      {% else %}
        <div class="product-faq__image-placeholder"> {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }} </div>
      {% endif %}
    </div>
  </div>

  <div class="product-faq__column product-faq__column--right">
    <div class="product-faq__content">
      <div class="product-faq__header">
        <h2 class="sparkles-title">
          {% if section.settings.enable_sparkles %}
            <span class="sparkles product-faq__sparkles">
              <span class="sparkle sparkle--1">
                <svg width="21" height="28" viewBox="0 0 21 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.1001 12.9001H15.6001C15.5001 12.9001 15.5001 12.9001 15.4001 12.9001H12.9001C12.8001 12.9001 12.7001 12.8001 12.6001 12.8001C11.7001 12.4001 11.4001 11.4001 11.1001 10.5001C10.9001 9.8001 10.7001 9.2001 10.6001 8.5001V0.200098C10.6001 -0.0999023 10.2001 -0.0999023 10.2001 0.200098V10.0001C10.1001 10.6001 10.0001 11.2001 9.6001 11.7001C9.5001 11.8001 9.4001 12.0001 9.3001 12.1001C8.6001 12.7001 7.5001 12.8001 6.6001 12.8001H6.5001H0.200098C-0.0999023 12.8001 -0.0999023 13.2001 0.200098 13.2001H7.3001H7.4001C9.3001 14.4001 10.0001 16.7001 10.2001 18.9001V26.9001C10.2001 27.2001 10.6001 27.2001 10.6001 26.9001V18.7001C11.0001 17.1001 11.5001 15.5001 12.6001 14.3001L12.7001 14.2001C13.2001 13.8001 13.8001 13.5001 14.5001 13.3001H20.2001C20.4001 13.3001 20.4001 12.9001 20.1001 12.9001Z" fill="currentColor"></path>
                </svg>
              </span>
              <span class="sparkle sparkle--2">
                <svg width="21" height="28" viewBox="0 0 21 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.1001 12.9001H15.6001C15.5001 12.9001 15.5001 12.9001 15.4001 12.9001H12.9001C12.8001 12.9001 12.7001 12.8001 12.6001 12.8001C11.7001 12.4001 11.4001 11.4001 11.1001 10.5001C10.9001 9.8001 10.7001 9.2001 10.6001 8.5001V0.200098C10.6001 -0.0999023 10.2001 -0.0999023 10.2001 0.200098V10.0001C10.1001 10.6001 10.0001 11.2001 9.6001 11.7001C9.5001 11.8001 9.4001 12.0001 9.3001 12.1001C8.6001 12.7001 7.5001 12.8001 6.6001 12.8001H6.5001H0.200098C-0.0999023 12.8001 -0.0999023 13.2001 0.200098 13.2001H7.3001H7.4001C9.3001 14.4001 10.0001 16.7001 10.2001 18.9001V26.9001C10.2001 27.2001 10.6001 27.2001 10.6001 26.9001V18.7001C11.0001 17.1001 11.5001 15.5001 12.6001 14.3001L12.7001 14.2001C13.2001 13.8001 13.8001 13.5001 14.5001 13.3001H20.2001C20.4001 13.3001 20.4001 12.9001 20.1001 12.9001Z" fill="currentColor"></path>
                </svg>
              </span>
              <span class="sparkle sparkle--3">
                <svg width="17" height="18" viewBox="0 0 17 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8.1 0L9.1 3.6C10.2 5.5 11.8 7 13.7 8.1L16.5 9L13.7 10C11.8 11 10.2 12.6 9.1 14.5L8.1 18L7.1 14.5C6.1 12.6 4.5 11 2.5 10L0 9L2.6 8C4.5 7 6.1 5.4 7.2 3.5L8.1 0Z" fill="currentColor"></path>
                </svg>
              </span>
              <span class="sparkle sparkle--4">
                <svg width="4" height="4" viewBox="0 0 4 4" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1.6 3.1C0.7 3.1 0 2.4 0 1.5C0 0.7 0.7 0 1.6 0C2.5 0 3.2 0.7 3.2 1.5C3.2 2.4 2.4 3.1 1.6 3.1Z" fill="currentColor"></path>
                </svg>
              </span>
            </span>
          {% endif %}
          {{ section.settings.heading }}
        </h2>
      </div>

      <div class="product-faq__items">
        {% for block in section.blocks %}
          {% assign index_label = forloop.index %}
          {% if forloop.index < 10 %}
            {% assign index_label = '0' | append: forloop.index %}
          {% endif %}
          <details
            class="product-faq__item{% if forloop.index > section.settings.load_more_after %} hide{% endif %}"
            data-product-faq-item
            {{ block.shopify_attributes }}
          >
            <summary>
              {{ index_label }}. {{ block.settings.question }}
              <svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g clip-path="url(#clip-product-faq-caret-{{ block.id }})">
                  <path d="M10.7488 9.12158L7.21327 12.6571L3.67773 9.12158" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                </g>
                <defs>
                  <clipPath id="clip-product-faq-caret-{{ block.id }}">
                    <rect width="10" height="10" fill="white" transform="translate(0.142578 8.00049) rotate(-45)"></rect>
                  </clipPath>
                </defs>
              </svg>
            </summary>
            <div class="product-faq__answer rte">{{ block.settings.answer }}</div>
          </details>
        {% endfor %}

        {% if section.blocks.size > section.settings.load_more_after %}
          <button type="button" class="product-faq__load-more text-link" aria-label="Load More" data-product-faq-load-more>
            {{ section.settings.load_more_label }}
          </button>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "section section-product-faq",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ"
    },
    {
      "type": "checkbox",
      "id": "enable_sparkles",
      "label": "Enable sparkles",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left image"
    },
    {
      "type": "range",
      "id": "load_more_after",
      "label": "Items visible before Load More",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "load_more_label",
      "label": "Load more label",
      "default": "Load More"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I use the Hair Oil?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Add your answer here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Product FAQ",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}